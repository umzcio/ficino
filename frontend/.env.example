# Frontend build-time configuration. Vite inlines VITE_* into the bundle
# at build time, so these must be available to `npm run build` — not at
# container start. In Railway, set these on the frontend service as
# build-time variables.

# URL the browser should hit for API calls. On self-host this is served
# by the outer proxy (e.g. /ficino/api), on SaaS it's the public Railway
# domain of the api service.
VITE_API_BASE=https://api.ficino.app

# Supabase client keys — only required when AUTH_PROVIDER=supabase on the
# API side. The anon key is safe to expose to the browser; the
# service-role key is NOT (it lives only in the api + worker env).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
