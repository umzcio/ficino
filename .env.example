# Persona temperature can be tuned per-persona via the personas.temperature
# column — leave null to use this user setting.

# Database
DATABASE_URL=postgresql://ficino:ficino@postgres:5432/ficino

# Redis
REDIS_URL=redis://redis:6379/0

# Provider selection
# LLM_PROVIDER: "ollama" (free, local) or "api" (Anthropic Claude)
# EMBED_PROVIDER: "ollama" (free, local), "openai", or "voyage"
# VISION_PROVIDER: "ollama" (free, local) or "api" (Claude Vision)
LLM_PROVIDER=ollama
EMBED_PROVIDER=ollama
VISION_PROVIDER=ollama

# Ollama (runs on host, accessed via host.docker.internal)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=qwen3.5:latest
OLLAMA_EMBED_MODEL=bge-m3:latest
OLLAMA_VISION_MODEL=gemma4:latest

# Embedding dimension (must match your embed model)
# 1024 = bge-m3, voyage-4-large
# 768  = nomic-embed-text
# 1536 = OpenAI text-embedding-3-small
EMBED_DIM=1024

# API Keys (used when *_PROVIDER=api)
#
# SECURITY: Do not paste real keys into a committed file. .env is in .gitignore
# so local development is fine, but for deployed environments (ficino.ai,
# staging) inject these at container start via a secret manager or CI env
# rather than baking them into an env_file. See docs/deployment.md (TODO).
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Voyage AI (used when EMBED_PROVIDER=voyage)
VOYAGE_API_KEY=your-voyage-key-here
VOYAGE_EMBED_MODEL=voyage-4-large

# OpenAI embedding model (used when EMBED_PROVIDER=openai)
OPENAI_EMBED_MODEL=text-embedding-3-small

# Claude model (used when LLM_PROVIDER=api or VISION_PROVIDER=api)
# claude-sonnet-4-6, claude-haiku-4-5
CLAUDE_MODEL=claude-sonnet-4-6

# Authentication
# AUTH_PROVIDER: "none" (no login, self-hosted default), "basic" (email/password), "supabase" (JWT)
AUTH_PROVIDER=none

# Basic auth (AUTH_PROVIDER=basic)
# ALLOW_REGISTRATION=true

# Supabase auth (AUTH_PROVIDER=supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_JWT_SECRET=your-jwt-secret
# Note: SUPABASE_ANON_KEY is a browser-side var (VITE_SUPABASE_ANON_KEY in
# frontend/.env), not read server-side — deliberately not documented here
# (R10 DEP-5: the api Settings mirror of this var had zero reads).

# Hosted / SaaS deployment lock. When true, Settings → AI hides LLM
# provider + API-key controls, and the settings-update endpoint drops
# any per-user attempt to override providers. Leave false on self-host
# so users can bring their own models.
PUBLIC_DEPLOYMENT=false

# Storage backend for PDFs + figure crops
# "local"    — filesystem under UPLOAD_DIR / FIGURES_DIR (default, self-host)
# "supabase" — Supabase Storage bucket (cloud deploy). Requires SUPABASE_URL,
#              SUPABASE_SERVICE_ROLE_KEY, and SUPABASE_STORAGE_BUCKET below.
STORAGE_PROVIDER=local
# SUPABASE_SERVICE_ROLE_KEY=eyJ...        # worker + api use this for PDF/figure I/O
# SUPABASE_STORAGE_BUCKET=papers           # bucket name; defaults to "papers"
# UPLOAD_DIR=/app/uploads                   # only used by STORAGE_PROVIDER=local
# FIGURES_DIR=/app/figures                  # only used by STORAGE_PROVIDER=local

# ElevenLabs TTS (feed audio playback). Leave empty to disable the feature.
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# CORS (comma-separated origins for production)
CORS_ORIGINS=https://ficino.app,https://ficino.ai

# Rate limits (per user, per day — only enforced when AUTH_PROVIDER != none)
# RATE_LIMIT_UPLOADS_PER_DAY=50
# RATE_LIMIT_GENERATIONS_PER_DAY=20
# RATE_LIMIT_USER_POSTS_PER_DAY=30

# App config
ENVIRONMENT=development
MAX_UPLOAD_SIZE_MB=50

# Cookie Domain. Set to a parent like ".ficino.app" on hosted deploys where
# frontend and api are on different subdomains and the frontend JS needs to
# read the CSRF cookie. Leave blank on self-host (same-origin, host-only
# cookie).
# COOKIE_DOMAIN=.ficino.app

# Server-side signed-URL signing key (figure/audio access tokens). Required
# when ENVIRONMENT=production — a dev fallback key is used otherwise, but
# don't rely on that outside local dev.
# SIGNED_URL_KEY=change-me-to-a-long-random-secret

# Feed-post search backend. true = normalized feed_posts table (tsvector,
# indexed); false = legacy in-memory JSONB scan. Default true.
# SEARCH_USE_NORMALIZED_POSTS=true

# Rate limit for one-shot LLM dispatch (paper summaries, group-chat
# syntheses) — separate from the per-day caps above.
# RATE_LIMIT_SUMMARY_PER_DAY=30

# Cross-encoder reranker (stage 3 over the hybrid candidate pool).
# RERANK_PROVIDER: "local" (BGE-reranker-v2-m3), "voyage", "cohere", or "none" to disable.
# RERANK_PROVIDER=none
# RERANK_LOCAL_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_VOYAGE_MODEL=rerank-2-lite
# RERANK_COHERE_MODEL=rerank-v3.5
# COHERE_API_KEY=your-cohere-key-here

# Contextual retrieval (Anthropic-style per-chunk contextual prefix at ingest time).
# CONTEXT_PROVIDER: "anthropic" (Claude Haiku, prompt-cached), "ollama", or "none".
# CONTEXT_PROVIDER=none
# CONTEXT_ANTHROPIC_MODEL=claude-haiku-4-5
# CONTEXT_OLLAMA_MODEL=qwen3.5:latest
# CONTEXT_MAX_PAPER_CHARS=200000
# CONTEXT_MAX_TOKENS=150

# Scientific-figure detection provider ("anthropic" | "ollama" | "none").
# FIGURE_DETECT_PROVIDER=anthropic

# Vision-fallback page cap (per paper) during PDF extraction.
# MAX_VISION_PAGES=100

# Podcast mode (Listen). Per-post TTS uses ELEVENLABS_MODEL_ID above;
# two-host dialogue mode uses this separate model.
# ELEVENLABS_DIALOGUE_MODEL_ID=eleven_v3

# Hybrid-search retrieval tuning.
# RETRIEVAL_CANDIDATE_POOL=100
# RETRIEVAL_RERANK_MULTIPLIER=5

# Celery task time limits (seconds). Soft raises SoftTimeLimitExceeded
# inside the task for cleanup; hard SIGKILLs the worker process shortly after.
# CELERY_SOFT_TIME_LIMIT=540
# CELERY_TIME_LIMIT=600

# DB connection pool sizes. API/worker-specific vars take precedence over
# the shared DB_POOL_* fallback; unset entirely to use the built-in
# per-service defaults (api 5-20, worker 2-10).
# API_DB_POOL_MIN_SIZE=5
# API_DB_POOL_MAX_SIZE=20
# WORKER_DB_POOL_MIN_SIZE=2
# WORKER_DB_POOL_MAX_SIZE=10

# Postgres / Redis passwords (docker-compose.yml reads these; both default
# to an empty/dev value if unset). IMPORTANT: if you set either of these,
# also update the matching DATABASE_URL / REDIS_URL above to embed the same
# password (e.g. postgresql://ficino:<POSTGRES_PASSWORD>@postgres:5432/ficino,
# redis://:<REDIS_PASSWORD>@redis:6379/0) — compose does not do this for you,
# and a mismatched URL fails to connect.
# POSTGRES_PASSWORD=ficino
# REDIS_PASSWORD=

# Celery
CELERY_WORKER_CONCURRENCY=2
