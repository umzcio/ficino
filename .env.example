# Database
DATABASE_URL=postgresql://ficino:ficino@postgres:5432/ficino

# Redis
REDIS_URL=redis://redis:6379/0

# Provider selection
# LLM_PROVIDER: "ollama" (free, local) or "api" (Anthropic Claude)
# EMBED_PROVIDER: "ollama" (free, local), "openai", or "voyage"
# VISION_PROVIDER: "ollama" (free, local) or "api" (Claude Vision)
LLM_PROVIDER=ollama
EMBED_PROVIDER=ollama
VISION_PROVIDER=ollama

# Ollama (runs on host, accessed via host.docker.internal)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=qwen3.5:latest
OLLAMA_EMBED_MODEL=bge-m3:latest
OLLAMA_VISION_MODEL=gemma4:latest

# Embedding dimension (must match your embed model)
# 1024 = bge-m3, voyage-4-large
# 768  = nomic-embed-text
# 1536 = OpenAI text-embedding-3-small
EMBED_DIM=1024

# API Keys (used when *_PROVIDER=api)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Voyage AI (used when EMBED_PROVIDER=voyage)
VOYAGE_API_KEY=your-voyage-key-here
VOYAGE_EMBED_MODEL=voyage-4-large

# OpenAI embedding model (used when EMBED_PROVIDER=openai)
OPENAI_EMBED_MODEL=text-embedding-3-small

# Claude model (used when LLM_PROVIDER=api or VISION_PROVIDER=api)
# claude-sonnet-4-6, claude-haiku-4-5
CLAUDE_MODEL=claude-sonnet-4-6

# CORS (comma-separated origins for production)
CORS_ORIGINS=https://ficino.ai,https://ficino.local

# App config
ENVIRONMENT=development
MAX_UPLOAD_SIZE_MB=50
GENERATION_LIMIT_PER_DAY=20

# Celery
CELERY_WORKER_CONCURRENCY=2
