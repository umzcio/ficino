# Database
DATABASE_URL=postgresql://ficino:ficino@postgres:5432/ficino

# Redis
REDIS_URL=redis://redis:6379/0

# Provider selection: "ollama" or "api"
# ollama = use local Ollama for LLM/embeddings (free, no API credits)
# api = use Anthropic Claude + OpenAI APIs
LLM_PROVIDER=ollama
EMBED_PROVIDER=ollama

# Ollama (runs on host, accessed via host.docker.internal)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=qwen3.5:latest
OLLAMA_EMBED_MODEL=mxbai-embed-large:latest
OLLAMA_VISION_MODEL=gemma4:latest

# Embedding dimension (must match your embed model)
# 1024 = mxbai-embed-large, bge-m3
# 768  = nomic-embed-text, nomic-embed-text-v2-moe
# 1536 = OpenAI text-embedding-3-small
# qwen3-embedding: varies by model size (check with ollama)
EMBED_DIM=1024

# API Keys (used when *_PROVIDER=api)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# App config
ENVIRONMENT=development
MAX_UPLOAD_SIZE_MB=50
GENERATION_LIMIT_PER_DAY=20

# Celery
CELERY_WORKER_CONCURRENCY=2
