# Template for .env.secrets. Copy to .env.secrets and fill in real values.
# .env.secrets is gitignored; this file is committed as the shape reference.
#
# docker-compose.yml loads .env AND .env.secrets via env_file.
# chmod 600 .env.secrets once created (owner read/write only).

ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
VOYAGE_API_KEY=your-voyage-key-here

# SUPABASE_JWT_SECRET=your-jwt-secret
# SUPABASE_ANON_KEY=eyJ...
